{
  "name": "website-kai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "paraglide:generate": "node scripts/generate-paraglide.mjs",
    "cf-typegen": "wrangler types --config wrangler.toml --env-interface CloudflareEnv cloudflare-env.d.ts",
    "build": "vite build",
    "dev": "vite dev --host 127.0.0.1 --port 3002",
    "preview": "vite build && vite preview --host 127.0.0.1 --port 3002",
    "lint": "pnpm run paraglide:generate && eslint src specs-tanstack vite.config.ts vitest.config.ts playwright.config.ts playwright.tanstack.config.ts tailwind.config.ts --ext .js,.cjs,.ts,.tsx",
    "check:tanstack-imports": "pnpm run paraglide:generate && node scripts/check-tanstack-imports.mjs",
    "check:tanstack-output": "node scripts/check-tanstack-output.mjs",
    "typecheck": "pnpm run paraglide:generate && pnpm run cf-typegen && tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e:tanstack": "node scripts/test-tanstack-e2e.mjs",
    "deploy": "vite build && wrangler deploy --config dist/server/wrangler.json",
    "upload": "vite build && wrangler versions upload --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@ibm/plex-sans": "^1.1.0",
    "@ibm/plex-sans-jp": "^3.0.0",
    "@ibm/plex-sans-kr": "^1.1.0",
    "@ibm/plex-sans-sc": "^1.1.0",
    "@ibm/plex-sans-tc": "^1.1.1",
    "@icons-pack/react-simple-icons": "^13.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@resvg/resvg-wasm": "^2.6.2",
    "@sentry/cloudflare": "10.64.0",
    "@sentry/tanstackstart-react": "10.64.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "compare-versions": "^6.1.1",
    "execa": "^9.6.0",
    "framer-motion": "^12.23.24",
    "jotai": "^2.15.0",
    "lodash": "^4.18.1",
    "lucide-react": "^1.0.0",
    "polished": "^4.3.1",
    "random": "^5.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "ua-parser-js": "2.0.10",
    "unified": "^11.0.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@cloudflare/workers-types": "^5.0.0",
    "@inlang/paraglide-js": "^2.20.2",
    "@inlang/plugin-m-function-matcher": "^2.2.9",
    "@inlang/plugin-message-format": "^4.4.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/eslint": "^8.56.12",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "fs-extra": "^11.3.2",
    "globby": "^16.0.0",
    "p-queue": "^9.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.9.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.0.0",
    "wrangler": "^4.103.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.37.0"
  },
  "packageManager": "pnpm@11.12.0"
}
