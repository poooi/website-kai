    "fs-extra": "^11.3.2",
    "globby": "^16.0.0",
    "p-queue": "^9.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
