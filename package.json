    "next": "^16.2.7",
    "next-i18n-router": "^5.5.4",
    "next-themes": "^0.4.6",
    "polished": "^4.3.1",
    "random": "^5.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.0",
