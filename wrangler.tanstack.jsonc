{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "poi-web-kai-tanstack-preview",
  "compatibility_date": "2026-06-21",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/worker.ts",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
